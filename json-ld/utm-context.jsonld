    "name": "name",
    "url": "url",
    "description": "description",
    "alternateName": "alternateName",
    "foundingDate": "foundingDate",
    "address": "address",
    "sameAs": "sameAs",
    "InstitutionalRepository": "utm:InstitutionalRepository",
    "oaiEndpoint": {
      "@id": "utm:oaiEndpoint",
